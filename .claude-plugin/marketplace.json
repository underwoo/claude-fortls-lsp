{
  "$schema": "https://anthropic.com/claude-code/marketplace.schema.json",
  "name": "fortls-lsp",
  "description": "Fortran language server plugin for Claude Code",
  "owner": {
    "name": "your-team"
  },
  "plugins": [
    {
      "name": "fortls-lsp",
      "version": "1.0.0",
      "description": "Fortran language server (fortls) for Claude Code — hover, go-to-definition, references, and diagnostics for Fortran source files",
      "author": {
        "name": "your-team"
      },
      "source": "./plugins/fortls-lsp",
      "category": "development",
      "lspServers": {
        "fortls": {
          "command": "fortls",
          "extensionToLanguage": {
            ".f90": "fortran",
            ".f":   "fortran",
            ".f03": "fortran",
            ".f08": "fortran",
            ".for": "fortran",
            ".fpp": "fortran",
            ".F90": "fortran",
            ".F":   "fortran",
            ".F03": "fortran",
            ".F08": "fortran",
            ".FOR": "fortran",
            ".FPP": "fortran"
          }
        }
      }
    }
  ]
}
